{
  "name": "translate-automator",
  "productName": "Translate Automator",
  "version": "1.0.7",
  "description": "Tradutor de roteiros PT-BR para EN-US com Claude Opus 4.7 e Gemini 3 Pro",
  "main": "dist-electron/main.js",
  "author": {
    "name": "Lucas Bazilio",
    "email": "heloysefreitas2@gmail.com"
  },
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "postinstall": "node scripts/postinstall.cjs",
    "dev": "vite",
    "dev:electron": "tsc -p electron/tsconfig.json && node scripts/run-electron.cjs",
    "electron:dev": "concurrently -k -n vite,electron -c blue,magenta \"npm run dev\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build:web": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:web && npm run build:electron",
    "package:mac": "npm run build && electron-builder --mac dmg zip --publish never",
    "package:win": "npm run build && electron-builder --win nsis --publish never",
    "release:mac": "npm run build && electron-builder --mac dmg zip --publish always",
    "release:win": "npm run build && electron-builder --win nsis --publish always",
    "typecheck": "tsc --noEmit && tsc --noEmit -p electron/tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@google/genai": "^0.10.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@types/turndown": "^5.0.6",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "docx": "^9.0.2",
    "electron-log": "^5.2.0",
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "lucide-react": "^0.460.0",
    "mammoth": "^1.8.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.5",
    "turndown": "^7.2.4",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wait-on": "^8.0.1"
  },
  "build": {
    "extends": null,
    "appId": "com.lucasbazilio.translateautomator",
    "productName": "Translate Automator",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "build",
      "output": "dist-builder"
    },
    "publish": {
      "provider": "github",
      "owner": "lucasbaziliocomercial-crypto",
      "repo": "translate-automator"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "artifactName": "${name}-${version}-${arch}-mac.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "artifactName": "${name}-setup-${version}.${ext}"
    }
  }
}
